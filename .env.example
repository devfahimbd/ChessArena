# ==============================================
# ChessArena - Environment Variables
# ==============================================
# Copy this file as .env and fill in your values
# cp .env.example .env
# ==============================================

# ─── DATABASE (Free MySQL - TiDB Cloud) ─────────
# TiDB Cloud theke connection string copy koro
# Format: mysql://user:pass@gateway01.us-east-1.prod.aws.tidbcloud.com:4000/chess_arena_db?ssl={"rejectUnauthorized":true}
DATABASE_URL="mysql://root:password@localhost:3306/chess_arena_db"

# ─── JWT Secret ──────────────────────────────────
# IMPORTANT: Google e likho "random password generator" -> 32 char password
JWT_SECRET="change-this-to-a-strong-random-secret-key-32chars"

# ─── Koyeb Backend URL ──────────────────────────
# Koyeb deploy er por URL bosabe
# Example: https://chess-arena-backend-xyz.koyeb.app
NEXT_PUBLIC_API_URL="http://localhost:10000"

# ─── Socket URL ─────────────────────────────────
# Combined server e same URL! Koyeb e ekta service e API + Socket
# NEXT_PUBLIC_SOCKET_URL na thakle NEXT_PUBLIC_API_URL use hobe
NEXT_PUBLIC_SOCKET_URL="http://localhost:10000"
