# ==============================================
# ChessArena - Environment Variables
# ==============================================
# Copy this file as .env and fill in your values
# cp .env.example .env
# ==============================================

# ─── DATABASE (MySQL - cPanel) ───────────────────
# cPanel থেকে MySQL database তৈরি করার পর
# নিচের format এ লিখো:
# mysql://DB_USERNAME:DB_PASSWORD@DB_HOST:3306/DB_NAME
DATABASE_URL="mysql://chess_user:YourPassword123@localhost:3306/chess_arena_db"

# ─── JWT Secret ──────────────────────────────────
# IMPORTANT: এটা একটা strong password দাও!
# Google এ লিখো "random password generator" এবং 32 character এর password ব্যবহার করো
JWT_SECRET="change-this-to-a-strong-random-secret-key-32chars"

# ─── RENDER.COM Backend URL ──────────────────────
# Render.com এ deploy করার পর এখানে তোমার backend URL বসাবে
# Example: https://chess-arena-backend.onrender.com
NEXT_PUBLIC_API_URL="https://your-backend.onrender.com"

# ─── RENDER.COM Socket Server URL ───────────────
# Render.com এ chess-server deploy করার পর এখানে URL বসাবে
# Example: https://chess-arena-socket.onrender.com
NEXT_PUBLIC_SOCKET_URL="https://your-socket-server.onrender.com"
